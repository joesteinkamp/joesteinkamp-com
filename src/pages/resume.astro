---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import { resume } from '../data/resume.ts';
---

<Base title="Resume">
  <div class="wrap">
    <div class="page-head">
      <div class="ey">{site.name} · {site.location}</div>
      <h1>Resume</h1>
    </div>
    <section style="padding-top:1vh">
      <div class="resume">
        <p class="prose" style="font-size:1.12rem;line-height:1.7">{resume.summary}</p>

        <h2 style="margin-top:5vh;font-size:1.1rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Experience</h2>
        {resume.experience.map((r) => (
          <div class="role">
            <div>
              <h3>{r.role}</h3>
              <div class="co">{r.company}{r.location ? ` · ${r.location}` : ''}</div>
            </div>
            <div class="pd">{r.period}</div>
            <ul>{r.highlights.map((h) => <li>{h}</li>)}</ul>
          </div>
        ))}

        <h2 style="margin-top:5vh;font-size:1.1rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Education</h2>
        {resume.education.map((e) => (
          <div class="role">
            <div>
              <h3>{e.degree}</h3>
              <div class="co">{e.school}</div>
            </div>
            <div class="pd">{e.period}</div>
          </div>
        ))}

        <h2 style="margin-top:5vh;font-size:1.1rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Skills</h2>
        <div class="skills">{resume.skills.map((s) => <span class="pill">{s}</span>)}</div>

        <div style="margin-top:5vh;display:flex;gap:12px;flex-wrap:wrap">
          <a class="btn" href={site.social.linkedin}>LinkedIn ↗</a>
          <a class="btn" href={site.social.email}>Email ↗</a>
        </div>
      </div>
    </section>
  </div>
</Base>
