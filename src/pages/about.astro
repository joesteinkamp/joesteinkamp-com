---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import { resume } from '../data/resume.ts';
---

<Base title="About">
  <div class="wrap">
    <div class="page-head">
      <div class="ey">{site.tagline} · {site.location}</div>
      <h1>About</h1>
    </div>
    <section style="padding-top:1vh">
      <div class="prose">
        <p>Hello, I'm Joe. {resume.summary}</p>
        <p>
          I've always been fascinated with technology — self-teaching front-end dev
          back in the GeoCities days — and equally drawn to understanding human
          behavior. I later combined the two with a degree in Human-Computer
          Interaction. I care about teams that ship, and about being the kind of
          leader who can still open the editor and build the thing.
        </p>
        <p>
          When I'm not focused on design and technology, I'm watching movies
          (especially sci-fi and horror — see <a href="/hhmm">HHMM</a>), hunting for
          the best donut shops and sour-beer breweries wherever I go, and hiking to
          burn it back off.
        </p>
        <p>
          Find me on <a href={site.social.github}>GitHub</a> and
          <a href={site.social.linkedin}> LinkedIn</a>, see the
          <a href="/resume"> resume</a>, or <a href={site.social.email}>say hello</a>.
        </p>
      </div>
    </section>
  </div>
</Base>
